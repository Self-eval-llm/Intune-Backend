# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-anon-key-here

# Ollama Configuration (optional)
# Default local Ollama server
OLLAMA_URL=http://localhost:11434

# Model Configuration (optional)
# Teacher model for data generation
TEACHER_MODEL=gpt-oss:20b

# Student model for initial inference
STUDENT_MODEL=gemma3:1b

# Fine-tuned model name
FINETUNED_MODEL=gemma-finetuned

# Training Configuration (optional)
# Maximum sequence length for training
MAX_SEQ_LENGTH=2048

# Batch size for training (adjust based on VRAM)
TRAIN_BATCH_SIZE=2

# Number of training epochs
NUM_EPOCHS=3

# Learning rate
LEARNING_RATE=0.0002

# Data Generation Configuration
# Number of training examples to generate
DATASET_SIZE=5000

# Batch size for data generation
GENERATION_BATCH_SIZE=15

# Delay between API calls (seconds)
API_DELAY=2.0
